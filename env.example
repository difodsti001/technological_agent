# ==============================
# BASE DE DATOS POSTGRESQL
# ==============================
DB_NAME=agente_tecnologico
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_SCHEMA=public
DB_POOL_MIN=2
DB_POOL_MAX=10

DB_TABLE_RECOMENDACION=data_recomendacion

# ==============================
# EXCEL
# ==============================
EXCEL_FALLBACK_PATH= G:\IA\technological_agent\data\DATA_RECOM.xlsx
EXCEL_SHEET_NAME=Sheet1


# ==============================
# SISTEMA DE RECOMENDACIÓN
# ==============================
# Número de cursos a recomendar por defecto (top_k)
REC_TOP_K=3
# Score mínimo para incluir un curso en resultados
REC_MIN_SCORE=0.05
# Nro de usuarios similares a considerar en filtro colaborativo
REC_TOP_K_SIMILAR_USERS=30
# Límite de usuarios para la matriz de similitud (protección RAM)
REC_MAX_USUARIOS_MATRIZ=15000
# Máx threads paralelos al llamar al LLM para justificaciones
REC_MAX_LLM_WORKERS=4

# Pesos del modelo híbrido (sumatoria: 1.0)
REC_PESO_COLABORATIVO=0.40
REC_PESO_POPULARIDAD=0.30
REC_PESO_HISTORIAL=0.20
REC_PESO_NOVEDAD=0.10

# ==============================
# MÓDULO SIFODS (chat RAG)
# ==============================
SIFODS_MAX_TOKENS=1500
SIFODS_TEMPERATURE=0.50
SIFODS_TOP_P=0.9

# ==============================
# LLM JUSTIFICACIONES
# ==============================
JUSTIF_MAX_TOKENS=250
JUSTIF_TEMPERATURE=0.75

# ==============================
# SERVIDOR
# ==============================
PORT=7002
LOG_LEVEL=INFO

# ==============================
# PERSISTENCIA
# ==============================
GUARDAR_CONVERSACIONES=true
GUARDAR_METRICAS=true
CACHE_TTL_SEGUNDOS=21600
# Ajuste según frecuencia de actualización de datos en PostgreSQL:
#   3600  = cada hora 
#   21600 = cada 6 horas
#   86400 = una vez al día